# Root-level env hints — not used directly by apps
# Each app/package has its own .env.example

# Node
NODE_ENV=development

# Shared infra (used by docker-compose)
POSTGRES_USER=saarthi
POSTGRES_PASSWORD=saarthi_secret
POSTGRES_DB=saarthi_dev
POSTGRES_PORT=5432

REDIS_PORT=6379

# Error reporting (optional) — see each workspace's .env.example
SENTRY_DSN=                 # backend (backend/api)
EXPO_PUBLIC_SENTRY_DSN=     # Expo apps (admin/parent/driver)
