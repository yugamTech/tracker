{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@yaanam/types": [
        "../../packages/types/src/index.ts"
      ],
      "@yaanam/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@yaanam/api-client": [
        "../../packages/api-client/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
