{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_ENV": "development" }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://api-staging.saarthi.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://api-staging.saarthi.app"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.saarthi.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.saarthi.app"
      }
    }
  }
}
