{
  "expo": {
    "name": "Saarthi Parent",
    "slug": "saarthi-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "saarthi-parent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saarthi.parent"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.saarthi.parent"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "saarthi-parent"
      }
    }
  }
}
