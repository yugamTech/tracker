# Replace with your machine's LAN IP when testing on a physical device.
# Find it with: ipconfig getifaddr en0   (Mac)
# The Android emulator uses 10.0.2.2 instead of localhost.
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# Optional: realtime socket host. Falls back to EXPO_PUBLIC_API_URL when unset
# (same host today). Set only if the socket lives on a different origin.
# EXPO_PUBLIC_SOCKET_URL=http://192.168.x.x:3000

# Error reporting (optional)
# Sentry DSN for crash/error reporting. Leave blank to disable — the app runs
# fine without it (Sentry init is skipped, captures are no-ops).
EXPO_PUBLIC_SENTRY_DSN=
