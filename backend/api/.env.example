# Backend environment variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://saarthi:saarthi_secret@localhost:5432/saarthi_dev?schema=public"
DATABASE_TEST_URL="postgresql://saarthi:saarthi_secret@localhost:5433/saarthi_test?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
# Set to true in dev to skip real SMS sending
OTP_BYPASS_MODE=true
OTP_BYPASS_CODE=123456

# Trips
# Minutes before a trip's scheduled start after which a parent can no longer
# cancel their child's pickup (PRD-02 FR-21).
PICKUP_CANCEL_CUTOFF_MINUTES=30

# Storage (Digital Ocean Spaces / S3)
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=ap-south-1

# Notifications
FCM_SERVER_KEY=
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock

# Payment Gateways
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox

# CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Error reporting (optional)
# Sentry DSN for backend error/crash reporting. Leave blank to disable — the
# app runs fine without it (Sentry init is skipped, captures are no-ops).
SENTRY_DSN=
